# Google OAuth (Workspace Phicus)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Cookie de sesión firmada (genera 64+ caracteres hex aleatorios)
SESSION_SECRET=replace-with-64-hex-chars

# Administradores con permisos para gestionar propuestas y periodo
ADMIN_EMAILS=jgomez@phicus.es,epastor@phicus.es

# Persistencia local
DB_PATH=./data/voting.db

# Entorno: development | production
ENV=development

# Base URL pública: origen donde el navegador del usuario ve la app.
# En dev DEBE ser la URL del frontend (Vite), no la del backend, para que el
# callback OAuth vuelva al origen donde corre la SPA. Vite proxea /auth y /api
# al backend automáticamente.
# Si Vite arranca en 5174 porque 5173 está ocupado, cambia esto a :5174.
BASE_URL=http://localhost:5173
